# Copy this file to .env and fill in your Jira credentials

# Jira instance URL (e.g., https://yourcompany.atlassian.net)
JIRA_URL=

# Your Jira email
JIRA_EMAIL=

# Your Jira API token (get from https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_API_TOKEN=

# LLM Model configuration
LLM_MODEL=qwen2.5:3b
LLM_TEMPERATURE=0.3